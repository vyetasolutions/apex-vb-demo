# Supabase project (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Demo mode: when true, the app runs on the in-memory/local mock engine
# (src/lib/store.ts) and never requires a live database — this is what
# ships by default so the demo runs on a laptop with zero setup.
# Set to "false" once Supabase is wired up (see docs/ARCHITECTURE.md).
NEXT_PUBLIC_DEMO_MODE=true
